# Copy to .env and adjust. All variables are optional; defaults match local dev.
# Prefix for every variable: BTL_

# BTL_OLLAMA_MODEL=llama3
# BTL_OLLAMA_TEMPERATURE=0.2
# BTL_EMBEDDING_MODEL=all-MiniLM-L6-v2
# BTL_RAG_RETRIEVER_K=3
# BTL_CHROMA_COLLECTION_NAME=bt_tickets

# Absolute paths if data/database live outside the repo (production):
# BTL_PROJECT_ROOT=/app
# BTL_DATA_RAW_DIR=/data/bt/raw
# BTL_CHROMA_PERSIST_DIR=/var/lib/bt/chroma_db
# BTL_CONVERSATIONS_DB_PATH=/var/lib/bt/conversations.db

# CORS: comma-separated origins, or * for any (dev only)
# BTL_CORS_ALLOW_ORIGINS=https://app.example.com,https://www.bt.bt
